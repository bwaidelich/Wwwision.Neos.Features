{
    "description": "Feature System for Neos including backend module to manage feature states",
    "type": "neos-package",
    "name": "wwwision/neos-features",
    "license": "MIT",
    "authors": [
        {
            "name": "Bastian Waidelich",
            "email": "b.waidelich@wwwision.de"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/bwaidelich"
        },
        {
            "type": "paypal",
            "url": "https://www.paypal.me/bwaidelich"
        }
    ],
    "require": {
        "php": ">=8.4",
        "wwwision/types": "^1.10",
        "neos/neos": "^8.4",
        "wwwision/neos-modulecomponents": "^1",
        "webmozart/assert": "^1 || ^2"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan": "^2",
        "friendsofphp/php-cs-fixer": "^3",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "Wwwision\\Neos\\Features\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wwwision\\Neos\\Features\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "neos/composer-plugin": true
        }
    },
    "extra": {
        "neos": {
            "package-key": "Wwwision.Neos.Features"
        }
    },
    "scripts": {
        "test:cs": "php-cs-fixer check",
        "test:cs:fix": "php-cs-fixer fix",
        "test:phpstan": "phpstan",
        "test:phpunit": "phpunit",
        "test": [
            "@test:cs",
            "@test:phpstan",
            "@test:phpunit"
        ]
    }
}
